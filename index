import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from 'firebase/auth';
import { getFirestore, doc, setDoc, getDoc, collection, query, onSnapshot, addDoc, updateDoc, deleteDoc, serverTimestamp } from 'firebase/firestore';
import { Plus, Trash2, Save, FileText, History, Printer, X, ChevronRight, Database, Tag } from 'lucide-react';

// Firebase configuration
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'may-studio-docs';

const STAMP_URL = 'stamp.png';
const MAY_INFO = {
  bizNo: "322-15-02616",
  name: "메이스튜디오",
  ceo: "정윤희",
  address: "창원시 성산구 중앙대로 33 대흥인터빌 519호",
  tel: "010-3560-5859",
  email: "contact@maystudio.kr",
  bank: "입금계좌 정보 (추후 수정 가능)"
};

export default function App() {
  const [user, setUser] = useState(null);
  const [docTitle, setDocTitle] = useState(''); // 과업 명칭 (예: 로고 디자인)
  const [clientName, setClientName] = useState('');
  const [invoiceDate, setInvoiceDate] = useState('');
  const [items, setItems] = useState([{ id: Date.now(), name: '', qty: '', price: '' }]);
  const [vatMode, setVatMode] = useState('exclude'); // 'exclude' or 'include'
  const [savedDocs, setSavedDocs] = useState([]);
  const [currentDocId, setCurrentDocId] = useState(null);
  const [isPreviewOpen, setIsPreviewOpen] = useState(false);
  const [previewType, setPreviewType] = useState('estimate');
  const [isSaving, setIsSaving] = useState(false);

  // Auth Initialization
  useEffect(() => {
    const initAuth = async () => {
      if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
        await signInWithCustomToken(auth, __initial_auth_token);
      } else {
        await signInAnonymously(auth);
      }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, setUser);
    return () => unsubscribe();
  }, []);

  // Sync Saved Documents
  useEffect(() => {
    if (!user) return;
    const q = collection(db, 'artifacts', appId, 'users', user.uid, 'invoices');
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setSavedDocs(docs);
    }, (error) => console.error("Firestore error:", error));
    return () => unsubscribe();
  }, [user]);

  const addItem = () => {
    setItems([...items, { id: Date.now(), name: '', qty: '', price: '' }]);
  };

  const updateItem = (id, field, value) => {
    setItems(items.map(item => item.id === id ? { ...item, [field]: value } : item));
  };

  const removeItem = (id) => {
    if (items.length > 1) {
      setItems(items.filter(item => item.id !== id));
    }
  };

  const calculateTotal = () => {
    let subtotal = 0;
    items.forEach(item => {
      const q = parseFloat(item.qty) || 0;
      const p = parseFloat(item.price) || 0;
      subtotal += (q * p);
    });
    
    if (vatMode === 'exclude') {
      return Math.round(subtotal * 1.1);
    }
    return Math.round(subtotal);
  };

  const handleSave = async () => {
    if (!user) return;
    if (!clientName) {
      alert("클라이언트명을 입력해주세요.");
      return;
    }
    
    setIsSaving(true);
    
    // 날짜 포맷 (YYMMDD)
    const now = new Date();
    const dateStr = now.getFullYear().toString().slice(-2) + 
                    (now.getMonth() + 1).toString().padStart(2, '0') + 
                    now.getDate().toString().padStart(2, '0');
    
    // 자동 제목 완성: [날짜]_[업체명]_[작성한내용]
    const taskName = docTitle.trim() || "문서";
    const finalFullTitle = `${dateStr}_${clientName}_${taskName}`;

    const docData = {
      docTitle: taskName, // 사용자가 입력한 과업명만 따로 저장
      fullTitle: finalFullTitle, // 전체 완성된 제목 저장
      clientName,
      invoiceDate,
      items,
      vatMode,
      updatedAt: serverTimestamp(),
      totalAmount: calculateTotal()
    };

    try {
      if (currentDocId) {
        await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'invoices', currentDocId), docData);
      } else {
        const docRef = await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'invoices'), {
          ...docData,
          createdAt: serverTimestamp()
        });
        setCurrentDocId(docRef.id);
      }
      alert("성공적으로 저장되었습니다.");
    } catch (e) {
      console.error(e);
      alert("저장 중 오류가 발생했습니다.");
    } finally {
      setIsSaving(false);
    }
  };

  const loadDoc = (doc) => {
    setDocTitle(doc.docTitle || '');
    setClientName(doc.clientName);
    setInvoiceDate(doc.invoiceDate || '');
    setItems(doc.items);
    setVatMode(doc.vatMode);
    setCurrentDocId(doc.id);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const deleteSavedDoc = async (e, id) => {
    e.stopPropagation();
    if (!confirm("정말 삭제하시겠습니까?")) return;
    try {
      await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'invoices', id));
      if (currentDocId === id) {
        createNew();
      }
    } catch (e) {
      console.error(e);
    }
  };

  const createNew = () => {
    setCurrentDocId(null);
    setDocTitle('');
    setClientName('');
    setInvoiceDate('');
    setItems([{ id: Date.now(), name: '', qty: '', price: '' }]);
  };

  const getPreviewData = () => {
    const formattedItems = items.filter(i => i.name).map(item => {
      const q = parseFloat(item.qty) || 0;
      const p = parseFloat(item.price) || 0;
      let sp = (vatMode === 'exclude') ? p : Math.round(p / 1.1);
      return { n: item.name, q, sp, amt: Math.round(q * sp) };
    });

    const subtotal = formattedItems.reduce((acc, cur) => acc + cur.amt, 0);
    const total = calculateTotal();
    const tax = total - subtotal;
    const [y, m, d] = invoiceDate ? invoiceDate.split('-') : ["    ", "  ", "  "];

    return { formattedItems, subtotal, total, tax, y, m, d };
  };

  const pd = getPreviewData();

  return (
    <div className="min-h-screen bg-slate-50 font-sans text-slate-900 pb-20">
      {/* Header */}
      <header className="max-w-5xl mx-auto p-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <div className="flex items-center gap-3">
          <div className="bg-blue-600 p-2 rounded-lg text-white">
            <FileText size={24} />
          </div>
          <div>
            <h1 className="text-xl font-black tracking-tight">메이스튜디오</h1>
            <p className="text-xs text-slate-500 font-medium">통합 문서 관리 시스템</p>
          </div>
        </div>
        <div className="flex gap-2">
          <button 
            onClick={createNew}
            className="flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm font-bold hover:bg-slate-50 transition-all"
          >
            <Plus size={16} /> 새 문서
          </button>
          <button 
            onClick={handleSave}
            disabled={isSaving}
            className="flex items-center gap-2 px-6 py-2 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-slate-800 transition-all shadow-md disabled:opacity-50"
          >
            <Save size={16} /> {isSaving ? "저장 중..." : "문서 저장"}
          </button>
        </div>
      </header>

      <main className="max-w-5xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div className="lg:col-span-2 space-y-6">
          {/* Main Input Area */}
          <section className="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm">
            {/* New: Document Title Input (Now Task Name Only) */}
            <div className="mb-8 p-4 bg-blue-50/50 rounded-2xl border border-blue-100/50">
              <label className="text-[10px] font-black text-blue-400 uppercase tracking-widest mb-2 block ml-1 flex items-center gap-1">
                <Tag size={10} /> 보관용 과업 명칭 (자동 완성: 날짜_업체명_작성내용)
              </label>
              <input 
                type="text" 
                value={docTitle}
                onChange={(e) => setDocTitle(e.target.value)}
                placeholder="예: 리플렛 디자인" 
                className="w-full bg-transparent border-b border-blue-200 py-2 focus:border-blue-500 outline-none transition-all font-bold text-blue-900 placeholder:text-blue-200"
              />
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
              <div>
                <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block ml-1">클라이언트 정보</label>
                <input 
                  type="text" 
                  value={clientName}
                  onChange={(e) => setClientName(e.target.value)}
                  placeholder="기관명 또는 성함" 
                  className="w-full p-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none transition-all font-bold"
                />
              </div>
              <div>
                <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block ml-1">발행 일자 (문서 표시용)</label>
                <input 
                  type="date" 
                  value={invoiceDate}
                  onChange={(e) => setInvoiceDate(e.target.value)}
                  className="w-full p-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none transition-all"
                />
              </div>
            </div>

            <div className="flex justify-between items-center mb-6">
              <h3 className="font-bold text-lg flex items-center gap-2">
                <Database size={18} className="text-blue-600" /> 과업 항목 리스트
              </h3>
              <div className="flex bg-slate-100 p-1 rounded-xl">
                <button 
                  onClick={() => setVatMode('exclude')}
                  className={`px-4 py-2 rounded-lg text-xs font-black transition-all ${vatMode === 'exclude' ? 'bg-white shadow-sm text-blue-600' : 'text-slate-500'}`}
                >
                  VAT 별도
                </button>
                <button 
                  onClick={() => setVatMode('include')}
                  className={`px-4 py-2 rounded-lg text-xs font-black transition-all ${vatMode === 'include' ? 'bg-white shadow-sm text-blue-600' : 'text-slate-500'}`}
                >
                  VAT 포함
                </button>
              </div>
            </div>

            <div className="space-y-4">
              {items.map((item, index) => (
                <div key={item.id} className="group flex flex-wrap md:flex-nowrap gap-3 items-end p-4 bg-slate-50 border border-slate-100 rounded-2xl transition-all hover:border-blue-200">
                  <div className="flex-1 min-w-[200px]">
                    <span className="text-[10px] font-bold text-slate-400 mb-1 block">품목 및 내역</span>
                    <input 
                      type="text" 
                      value={item.name}
                      onChange={(e) => updateItem(item.id, 'name', e.target.value)}
                      placeholder="과업 내용을 입력하세요"
                      className="w-full p-3 bg-white border border-slate-100 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none"
                    />
                  </div>
                  <div className="w-20">
                    <span className="text-[10px] font-bold text-slate-400 mb-1 block text-center">수량</span>
                    <input 
                      type="number" 
                      value={item.qty}
                      onChange={(e) => updateItem(item.id, 'qty', e.target.value)}
                      placeholder="1"
                      className="w-full p-3 bg-white border border-slate-100 rounded-xl text-sm text-center outline-none"
                    />
                  </div>
                  <div className="w-32">
                    <span className="text-[10px] font-bold text-slate-400 mb-1 block text-right">단가(원)</span>
                    <input 
                      type="number" 
                      value={item.price}
                      onChange={(e) => updateItem(item.id, 'price', e.target.value)}
                      placeholder="0"
                      className="w-full p-3 bg-white border border-slate-100 rounded-xl text-sm text-right font-bold outline-none"
                    />
                  </div>
                  <button 
                    onClick={() => removeItem(item.id)}
                    className="p-3 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all"
                  >
                    <Trash2 size={18} />
                  </button>
                </div>
              ))}
            </div>

            <button 
              onClick={addItem}
              className="mt-6 w-full py-4 border-2 border-dashed border-slate-200 rounded-2xl text-slate-400 font-bold hover:bg-slate-50 hover:text-blue-500 hover:border-blue-200 transition-all flex justify-center items-center gap-2"
            >
              <Plus size={18} /> 항목 추가하기
            </button>
          </section>

          {/* Quick Actions / Summary */}
          <div className="bg-slate-900 rounded-3xl p-8 text-white flex flex-col md:flex-row justify-between items-center gap-6 shadow-xl">
            <div>
              <p className="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Total Amount</p>
              <h2 className="text-4xl font-black tracking-tighter">{pd.total.toLocaleString()}원</h2>
            </div>
            <div className="flex gap-2 w-full md:w-auto">
              <button 
                onClick={() => { setPreviewType('estimate'); setIsPreviewOpen(true); }}
                className="flex-1 md:flex-none px-8 py-4 bg-blue-600 rounded-2xl font-black hover:bg-blue-500 transition-all shadow-lg active:scale-95"
              >
                문서 미리보기
              </button>
            </div>
          </div>
        </div>

        {/* Sidebar: Saved Documents */}
        <aside className="space-y-6">
          <div className="bg-white p-6 rounded-3xl border border-slate-200 shadow-sm">
            <h3 className="font-bold text-lg mb-4 flex items-center gap-2">
              <History size={18} className="text-blue-600" /> 보관함
            </h3>
            <div className="space-y-3 max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
              {savedDocs.length === 0 ? (
                <div className="text-center py-10">
                  <div className="text-slate-300 mb-2 flex justify-center"><Database size={40} /></div>
                  <p className="text-sm text-slate-400 font-medium">저장된 문서가 없습니다.</p>
                </div>
              ) : (
                savedDocs.sort((a,b) => (b.updatedAt?.seconds || 0) - (a.updatedAt?.seconds || 0)).map(doc => (
                  <div 
                    key={doc.id}
                    onClick={() => loadDoc(doc)}
                    className={`group p-4 rounded-2xl border transition-all cursor-pointer ${currentDocId === doc.id ? 'border-blue-500 bg-blue-50/50' : 'border-slate-100 bg-slate-50 hover:border-slate-300'}`}
                  >
                    <div className="flex justify-between items-start mb-1">
                      <span className="text-[10px] font-black text-blue-600 bg-white px-2 py-0.5 rounded border border-blue-100 truncate max-w-[150px]">
                        {doc.fullTitle || doc.docTitle || doc.clientName}
                      </span>
                      <button 
                        onClick={(e) => deleteSavedDoc(e, doc.id)}
                        className="text-slate-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all"
                      >
                        <Trash2 size={14} />
                      </button>
                    </div>
                    <h4 className="font-bold text-slate-800 text-sm truncate mt-1">
                      {doc.clientName}
                    </h4>
                    <p className="text-[10px] text-slate-400 mt-1 font-medium">
                      {doc.updatedAt?.seconds ? new Date(doc.updatedAt.seconds * 1000).toLocaleDateString() : '날짜 없음'} • {doc.totalAmount?.toLocaleString()}원
                    </p>
                  </div>
                ))
              )}
            </div>
          </div>

          <div className="bg-blue-600 rounded-3xl p-6 text-white overflow-hidden relative">
            <div className="relative z-10">
              <h4 className="font-black text-lg mb-1 italic">MAY STUDIO TIP</h4>
              <p className="text-xs opacity-90 leading-relaxed font-medium">
                과업 명칭만 짧게 입력해 주세요. 업체명과 날짜는 제가 알아서 붙여드릴게요!
              </p>
            </div>
            <FileText className="absolute -bottom-4 -right-4 opacity-10 rotate-12" size={120} />
          </div>
        </aside>
      </main>

      {/* Preview Modal Overlay */}
      {isPreviewOpen && (
        <div className="fixed inset-0 bg-slate-900/95 backdrop-blur-sm z-[100] overflow-y-auto pt-4 pb-20">
          <div className="sticky top-0 z-[110] max-w-5xl mx-auto px-4 py-4 flex justify-between items-center gap-4">
             <button 
              onClick={() => setIsPreviewOpen(false)}
              className="px-6 py-2 bg-white text-slate-900 rounded-xl font-bold flex items-center gap-2 hover:bg-slate-100 transition-all"
            >
              <X size={18} /> 편집으로 돌아가기
            </button>
            <div className="flex bg-slate-800/80 p-1 rounded-2xl border border-white/10">
              <button 
                onClick={() => setPreviewType('estimate')}
                className={`px-4 py-2 rounded-xl text-xs font-bold transition-all ${previewType === 'estimate' ? 'bg-blue-600 text-white' : 'text-slate-400'}`}
              >
                견적서
              </button>
              <button 
                onClick={() => setPreviewType('statement')}
                className={`px-4 py-2 rounded-xl text-xs font-bold transition-all ${previewType === 'statement' ? 'bg-slate-600 text-white' : 'text-slate-400'}`}
              >
                거래명세서
              </button>
              <button 
                onClick={() => setPreviewType('receipt')}
                className={`px-4 py-2 rounded-xl text-xs font-bold transition-all ${previewType === 'receipt' ? 'bg-emerald-600 text-white' : 'text-slate-400'}`}
              >
                영수증
              </button>
            </div>
            <button 
              onClick={() => window.print()}
              className="px-8 py-2.5 bg-blue-500 text-white rounded-xl font-bold flex items-center gap-2 shadow-lg hover:bg-blue-400 transition-all"
            >
              <Printer size={18} /> 인쇄 / PDF 저장
            </button>
          </div>

          <div id="print-area" className="flex justify-center p-4">
            <div className="bg-white shadow-2xl overflow-hidden print-page-shadow" style={{ width: '210mm', minHeight: '297mm', padding: '15mm' }}>
              <h1 className="text-center font-black underline underline-offset-8 decoration-2 mb-12 tracking-[15px] text-4xl uppercase">
                {previewType === 'estimate' ? '견 적 서' : (previewType === 'statement' ? '거 래 명 세 서' : '영 수 증')}
              </h1>

              <div className="flex justify-between items-start mb-8">
                <div className="w-[45%]">
                  <div className="text-2xl font-bold border-b-2 border-black inline-block pb-1 pr-6 mb-2">
                    {clientName || "(기관/성함 미입력)"} <span className="text-lg font-normal ml-1">귀하</span>
                  </div>
                  <div className="text-lg font-medium">
                    {pd.y}년 {pd.m}월 {pd.d}일
                  </div>
                  <div className="text-xs text-slate-600 mt-4 leading-relaxed">
                    아래와 같이 {previewType === 'estimate' ? '견적합니다' : (previewType === 'statement' ? '명세합니다' : '영수합니다(또는 청구합니다)')}.
                  </div>
                </div>

                <div className="w-[380px]">
                  <table className="w-full border-collapse border border-black text-[11px]">
                    <tbody>
                      <tr>
                        <td className="border border-black bg-slate-50 font-bold text-center w-20 py-2">사업자번호</td>
                        <td colSpan="3" className="border border-black text-center font-bold text-[13px]">{MAY_INFO.bizNo}</td>
                      </tr>
                      <tr>
                        <td className="border border-black bg-slate-50 font-bold text-center py-2">상 호</td>
                        <td className="border border-black text-center font-bold">{MAY_INFO.name}</td>
                        <td className="border border-black bg-slate-50 font-bold text-center w-14">대표자</td>
                        <td className="border border-black text-center relative py-2">
                          <span className="font-bold relative z-10">{MAY_INFO.ceo}</span>
                          <span className="ml-2 relative z-10">(인)</span>
                          <img src={STAMP_URL} className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 z-0 opacity-80" alt="인감" />
                        </td>
                      </tr>
                      <tr>
                        <td className="border border-black bg-slate-50 font-bold text-center py-2">주 소</td>
                        <td colSpan="3" className="border border-black text-left px-2 leading-tight py-2">{MAY_INFO.address}</td>
                      </tr>
                      <tr>
                        <td className="border border-black bg-slate-50 font-bold text-center py-2">전화번호</td>
                        <td className="border border-black text-center">{MAY_INFO.tel}</td>
                        <td className="border border-black bg-slate-50 font-bold text-center">E-mail</td>
                        <td className="border border-black text-center text-[10px] whitespace-pre-wrap">{MAY_INFO.email.replace('@', '\n@')}</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <table className="w-full border-collapse border border-black text-[12px] mb-6">
                <thead>
                  <tr className="bg-slate-50">
                    <th className="border border-black py-2 w-10">No</th>
                    <th className="border border-black">품목 및 과업내역</th>
                    <th className="border border-black w-12">수량</th>
                    <th className="border border-black w-24">단가(원)</th>
                    <th className="border border-black w-32">금액(원)</th>
                    <th className="border border-black w-16">비고</th>
                  </tr>
                </thead>
                <tbody>
                  {pd.formattedItems.map((item, idx) => (
                    <tr key={idx} className="min-h-[35px]">
                      <td className="border border-black text-center py-2">{idx + 1}</td>
                      <td className="border border-black text-left px-3 py-2 leading-relaxed whitespace-pre-wrap">{item.n}</td>
                      <td className="border border-black text-center">{item.q}</td>
                      <td className="border border-black text-right px-2">{item.sp.toLocaleString()}</td>
                      <td className="border border-black text-right px-2 font-bold">{item.amt.toLocaleString()}</td>
                      <td className="border border-black"></td>
                    </tr>
                  ))}
                  {Array.from({ length: Math.max(0, 15 - pd.formattedItems.length) }).map((_, idx) => (
                    <tr key={`empty-${idx}`} className="h-[35px]">
                      <td className="border border-black text-center">{pd.formattedItems.length + idx + 1}</td>
                      <td className="border border-black"></td>
                      <td className="border border-black"></td>
                      <td className="border border-black"></td>
                      <td className="border border-black"></td>
                      <td className="border border-black"></td>
                    </tr>
                  ))}
                </tbody>
                <tfoot>
                  <tr className="h-[38px]">
                    <td colSpan="4" className="border border-black text-right pr-6 bg-slate-50 font-bold">공급가액 소계</td>
                    <td className="border border-black text-right px-2 font-bold">{pd.subtotal.toLocaleString()}</td>
                    <td rowSpan="3" className="border border-black"></td>
                  </tr>
                  <tr className="h-[38px]">
                    <td colSpan="4" className="border border-black text-right pr-6 bg-slate-50 font-bold">부가세액 (10%)</td>
                    <td className="border border-black text-right px-2 font-bold">{pd.tax.toLocaleString()}</td>
                  </tr>
                  <tr className="h-[48px] bg-slate-100">
                    <td colSpan="4" className="border border-black text-right pr-6 font-black text-lg">합계금액 (총액)</td>
                    <td className="border border-black text-right px-2 font-black text-lg text-blue-700">{pd.total.toLocaleString()}</td>
                  </tr>
                </tfoot>
              </table>

              <div className="mt-8">
                <div className="p-4 border border-slate-300 rounded-xl font-bold bg-slate-50 flex items-center gap-4 mb-6">
                  <span className="bg-blue-600 text-white px-2 py-0.5 rounded text-xs">입금계좌</span>
                  <span>{MAY_INFO.bank}</span>
                </div>
                <ul className="text-[11px] text-slate-500 space-y-1 list-disc pl-5">
                  <li>본 문서는 발행일로부터 30일간 유효합니다.</li>
                  <li>상기 금액은 VAT 정책에 따라 계산되었으며, 작업 범위 변경 시 변동될 수 있습니다.</li>
                  <li>작업 완료 후 정식 전자세금계산서 발행이 가능합니다.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Global CSS for Print */}
      <style dangerouslySetInnerHTML={{ __html: `
        @media print {
          body * { visibility: hidden; background: white !important; }
